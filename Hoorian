<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hoorain Store</title>

<style>
body { font-family: Arial; margin: 0; }

header {
  background: black;
  color: white;
  text-align: center;
  padding: 15px;
}

nav {
  background: #444;
  text-align: center;
  padding: 10px;
}

nav a {
  color: white;
  margin: 10px;
  text-decoration: none;
}

section { padding: 20px; }

.products {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
}

.product {
  border: 1px solid #ddd;
  padding: 10px;
  width: 220px;
  text-align: center;
}

.product img {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.btn {
  display: inline-block;
  margin-top: 10px;
  padding: 8px;
  background: green;
  color: white;
  text-decoration: none;
  cursor: pointer;
}

.cart {
  position: fixed;
  top: 10px;
  right: 10px;
  background: orange;
  padding: 10px;
}

footer {
  background: black;
  color: white;
  text-align: center;
  padding: 10px;
}

.whatsapp {
  position: fixed;
  bottom: 20px;
  right: 20px;
  background: #25D366;
  color: white;
  padding: 15px;
  border-radius: 50%;
  text-decoration: none;
  font-size: 20px;
}
</style>
</head>

<body>

<header>
  <h1>Hoorain Store</h1>
  <p>Perfumes | Itr | Watches</p>
</header>

<div class="cart">
  🛒 Cart: <span id="cart-count">0</span>
</div>

<nav>
  <a href="#home">Home</a>
  <a href="#products">Products</a>
  <a href="#contact">Contact</a>
</nav>

<section id="home">
  <h2>Welcome to Hoorain</h2>
  <p>Best perfumes, itr & watches at best prices.</p>
</section>

<section id="products">
  <h2>Our Products</h2>

  <div class="products">

    <div class="product">
      <img src="https://images.unsplash.com/photo-1594035910387-fea47794261f">
      <h3>Luxury Perfume</h3>
      <p>Rs.1500</p>
      <button class="btn" onclick="addToCart('Luxury Perfume')">Add to Cart</button>
    </div>

    <div class="product">
      <img src="https://images.unsplash.com/photo-1600185365926-3a2ce3cdb9eb">
      <h3>Premium Itr</h3>
      <p>Rs.1200</p>
      <button class="btn" onclick="addToCart('Premium Itr')">Add to Cart</button>
    </div>

    <div class="product">
      <img src="https://images.unsplash.com/photo-1519744346363-d93dbafc7f7d">
      <h3>Stylish Watch</h3>
      <p>Rs.3000</p>
      <button class="btn" onclick="addToCart('Stylish Watch')">Add to Cart</button>
    </div>

  </div>

  <br>
  <button class="btn" onclick="orderNow()">Order via WhatsApp</button>

</section>

<section id="contact">
  <h2>Contact & Payment</h2>
  <p>WhatsApp: 923261089570</p>
  <p>JazzCash: 923261089570</p>
</section>

<footer>
  <p>© 2026 Hoorain Store</p>
</footer>

<a class="whatsapp" href="https://wa.me/923261089570">💬</a>

<script>
let cart = [];

function addToCart(product) {
  cart.push(product);
  document.getElementById("cart-count").innerText = cart.length;
}

function orderNow() {
  let message = "Order Details:\n" + cart.join("\n") + "\nPayment: JazzCash";
  let url = "https://wa.me/923261089570?text=" + encodeURIComponent(message);
  window.open(url, "_blank");
}
</script>

</body>
</html>
